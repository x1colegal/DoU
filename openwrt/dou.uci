config dou 'main'
	option enabled '0'
	option server 'x1co.com.br'
	option peer_port '4053'
	option bind_ip '0.0.0.0'
	option bind_port '0'
	option local_dns_ip '127.0.0.1'
	option local_dns_port '4333'
	option cipher 'chacha20'
	option congestion_control 'off'
	option cleartext 'off'
	option tofu_file '/etc/dou_known_hosts.json'
	option dnsmasq_forwarding '1'
